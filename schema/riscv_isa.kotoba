// Riscv_isa clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace riscv_isa {

    entity Register {
        id: string @unique
        name: string
        widthBits: integer
        role: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Instruction {
        id: string @unique
        mnemonic: string
        opcode: string
        operands: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Qubit {
        id: string @unique
        index: integer
        t1Us: float
        t2Us: float
        readoutError: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Circuit {
        id: string @unique
        name: string
        qubitCount: integer
        depth: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Gate {
        id: string @unique
        circuitId: string
        name: string
        targets: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Job {
        id: string @unique
        circuitId: string
        shots: integer
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
